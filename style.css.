*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
background:#efe5d2;
font-family:Arial,sans-serif;
color:#3d2314;
overflow-x:hidden;
}

/* Фон под старую бумагу */

.background{
position:fixed;
width:100%;
height:100%;
left:0;
top:0;
z-index:-1;
background:
radial-gradient(circle at 20% 20%,rgba(255,255,255,.3),transparent 35%),
radial-gradient(circle at 80% 70%,rgba(255,255,255,.25),transparent 30%),
linear-gradient(#efe5d2,#f8f3ea);
}

/* Шапка */

header{

text-align:center;

padding:30px 20px;

}

.seal{

width:65px;

height:65px;

margin:auto;

border:3px solid #962222;

color:#962222;

font-size:34px;

display:flex;

align-items:center;

justify-content:center;

border-radius:10px;

font-family:"Noto Serif SC",serif;

margin-bottom:15px;

}

h1{

font-family:"Cinzel",serif;

font-size:42px;

color:#8c1f1f;

letter-spacing:2px;

}

header p{

margin-top:10px;

font-size:18px;

color:#8d6f48;

}

/* HSK */

.levels{

display:flex;

justify-content:center;

gap:12px;

margin:20px;

flex-wrap:wrap;

}

.levels button{

padding:10px 18px;

border:none;

background:#f5efe5;

border:2px solid #cba04a;

border-radius:30px;

font-size:17px;

cursor:pointer;

transition:.3s;

}

.levels button.active{

background:#9b2020;

color:white;

}

/* Карточка */

.card{

width:340px;

height:400px;

margin:40px auto;

position:relative;

transform-style:preserve-3d;

transition:1s;

cursor:pointer;

}

.card.flip{

transform:rotateY(180deg);

}

.front,

.back{

position:absolute;

width:100%;

height:100%;

border-radius:28px;

backface-visibility:hidden;

display:flex;

flex-direction:column;

justify-content:center;

align-items:center;

background:#fbf6ee;

border:3px solid #cba04a;

box-shadow:0 12px 35px rgba(0,0,0,.12);

padding:25px;

}

/* декоративные уголки */

.front:before,
.front:after,
.back:before,
.back:after{

content:"";

position:absolute;

width:45px;

height:45px;

border:3px solid #b58a39;

}

.front:before,
.back:before{

top:15px;

left:15px;

border-right:none;

border-bottom:none;

}

.front:after,
.back:after{

bottom:15px;

right:15px;

border-left:none;

border-top:none;

}

.back{

transform:rotateY(180deg);

}

.level{

font-size:20px;

color:#9b2020;

margin-bottom:20px;

}

.word{

font-family:"Noto Serif SC",serif;

font-size:90px;

color:#761515;

}

.word-small{

font-size:70px;

font-family:"Noto Serif SC",serif;

color:#761515;

}

.pinyin{

font-size:34px;

margin:20px 0;

color:#a57b1c;

}

.translation{

font-size:30px;

}

.tap{

margin-top:30px;

font-size:18px;

color:#999;

}

/* Кнопки */

.buttons{

width:340px;

margin:auto;

}

#speak{

width:100%;

padding:18px;

background:#982020;

color:white;

border:none;

border-radius:18px;

font-size:22px;

cursor:pointer;

transition:.3s;

}

#speak:hover{

background:#7a1515;

}

.nav{

display:flex;

gap:15px;

margin-top:15px;

}

.nav button{

flex:1;

padding:16px;

font-size:20px;

background:#c9a04d;

border:none;

border-radius:18px;

cursor:pointer;

color:#4a2b17;

transition:.3s;

}

.nav button:hover{

transform:scale(1.05);

}

/* Прогресс */

.progress{

width:340px;

margin:35px auto;

}

.progress-title{

margin-bottom:10px;

text-align:center;

}

.bar{

height:16px;

background:#ddd2bd;

border-radius:20px;

overflow:hidden;

}

.fill{

height:100%;

width:15%;

background:#9b2020;

}

.percent{

text-align:center;

margin-top:8px;

font-size:18px;

}

footer{

text-align:center;

padding:30px;

color:#8b7153;

}

/* Телефон */

@media(max-width:420px){

.card,

.buttons,

.progress{

width:92%;

}

.word{

font-size:72px;

}

.word-small{

font-size:60px;

}

}