let level = 1;
let index = 0;

const card = document.querySelector(".card");
const word = document.querySelector(".word");
const wordSmall = document.querySelector(".word-small");
const pinyin = document.querySelector(".pinyin");
const translation = document.querySelector(".translation");
const levelText = document.querySelector(".level");
const fill = document.querySelector(".fill");
const percent = document.querySelector(".percent");

function updateCard(){

let w = words[level][index];

word.textContent = w.cn;
wordSmall.textContent = w.cn;
pinyin.textContent = w.py;
translation.textContent = w.ru;

levelText.textContent = "HSK " + level;

let progress = ((index+1)/words[level].length)*100;

fill.style.width = progress + "%";
percent.textContent = Math.round(progress) + "%";

card.classList.remove("flip");

}

updateCard();

/* Перевернуть карточку */

card.onclick = ()=>{

card.classList.toggle("flip");

};

/* Следующее */

document.getElementById("next").onclick=()=>{

index++;

if(index>=words[level].length){

index=0;

}

updateCard();

};

/* Предыдущее */

document.getElementById("prev").onclick=()=>{

index--;

if(index<0){

index=words[level].length-1;

}

updateCard();

};

/* Озвучка */

document.getElementById("speak").onclick=()=>{

let utter = new SpeechSynthesisUtterance(words[level][index].cn);

utter.lang="zh-CN";

utter.rate=0.8;

speechSynthesis.cancel();

speechSynthesis.speak(utter);

};

/* Выбор HSK */

document.querySelectorAll(".levels button").forEach((btn,i)=>{

btn.onclick=()=>{

document.querySelector(".levels .active").classList.remove("active");

btn.classList.add("active");

level=i+1;

index=0;

updateCard();

};

});